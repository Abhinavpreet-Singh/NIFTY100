# Nifty 100 Financial Intelligence Platform
# Environment Configuration Template
# Copy to .env and fill in actual values

# ============================================================
# PROJECT SETTINGS
# ============================================================
PROJECT_NAME=Nifty 100 Financial Intelligence Platform
PROJECT_ENV=development
DEBUG=True

# ============================================================
# DATA PATHS
# ============================================================
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
REPORTS_DIR=./reports
LOGS_DIR=./logs

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_PATH=./data/nifty100.db
DB_ECHO=False

# ============================================================
# ETL SETTINGS
# ============================================================
# Excel loader settings
EXCEL_HEADER_ROW=1  # 0-indexed (Row 1 = header, Row 0 = metadata)
EXCEL_SHEET_NAMES=Companies|Profit & Loss|Balance Sheet|Cash Flow|Analysis|Documents|Pros & Cons

# Data validation
MIN_COMPANIES=85
MIN_YEARS_PER_COMPANY=8

# ============================================================
# ANALYTICS SETTINGS
# ============================================================
# Financial ratio computation
TOLERANCE_PCT=1.0  # Tolerance for validation checks (%)
CAGR_MIN_YEARS=3

# Screener settings
SCREENER_MIN_RESULTS=5
SCREENER_MAX_RESULTS=100

# ============================================================
# DASHBOARD SETTINGS
# ============================================================
STREAMLIT_PORT=8501
STREAMLIT_THEME=light

# ============================================================
# API SETTINGS
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/nifty100.log

# ============================================================
# EXTERNAL SERVICES
# ============================================================
# Add any third-party API keys or service URLs here
# TRADINGVIEW_API_KEY=xxx
# NSE_API_URL=https://www.nseindia.com/api/

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_PDF_GENERATION=True
ENABLE_EXCEL_EXPORT=True
ENABLE_ALERTS=False
ENABLE_NLP_SUMMARIZER=False
